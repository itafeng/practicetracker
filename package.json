{
  "name": "leetpractice",
  "version": "1.0.0",
  "description": "LeetCode Practice Tracker with Spaced Repetition",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "setup": "npm install && cd client && npm install"
  },
  "keywords": ["leetcode", "practice", "tracker"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "better-sqlite3": "^9.2.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}